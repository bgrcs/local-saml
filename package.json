{
  "name": "local-saml-idp",
  "version": "1.0.1",
  "description": "Local SAML 2.0 IdP emulator for development testing",
  "type": "module",
  "bin": {
    "local-saml-idp": "./bin/local-saml.js",
    "local-saml": "./bin/local-saml.js"
  },
  "files": [
    "bin/",
    "client/",
    "dist/",
    "server.ts",
    "saml.ts",
    "store.ts"
  ],
  "scripts": {
    "start": "bun run server.ts",
    "dev": "bun --watch server.ts",
    "build": "NODE_ENV=production bun build ./client/main.tsx --outfile ./dist/bundle.js --bundle --target browser --jsx-import-source react",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "saml",
    "saml2",
    "idp",
    "identity-provider",
    "sso",
    "development",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "node-forge": "^1.3.1",
    "xml-crypto": "^3.2.0",
    "@xmldom/xmldom": "^0.8.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-forge": "^1.3.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
